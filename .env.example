# QuickBooks Online OAuth 2.0
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here
QBO_REFRESH_TOKEN=your_refresh_token_here
QBO_REALM_ID=your_company_id_here
QBO_REDIRECT_URI=http://localhost:8000/callback

# Google Sheets (opcional — deixe vazio se usar JSON local)
GOOGLE_SHEETS_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# Alertas por email (opcional)
ALERT_EMAIL_FROM=noreply@brasa.org
ALERT_EMAIL_TO=financeiro@brasa.org
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
